        "POST /api/image/resize — sharp 尺寸调整",
        "POST /api/image/upscale — lanczos3 放大",
        "POST /api/image/grid-crop — 九宫格切图",
        "POST /api/image/combine — 横/纵向拼接",
        "POST /api/image/remove-bg — 抠图(占位)"
      ],
      "proxy": [
        "POST /api/proxy/image — 图像生成(贞贞工坊,自动转存)",
        "POST /api/proxy/llm — LLM Chat(独立 Key)",
        "POST /api/proxy/video/submit — 视频任务提交",
        "GET /api/proxy/video/query?taskId — 视频任务轮询(转存)",
        "POST /api/proxy/audio/submit — Suno 提交(generate/cover/extend)",
        "GET /api/proxy/audio/query?clipIds — Suno 轮询",
        "POST /api/proxy/runninghub/submit — RH 工作流提交",
        "GET /api/proxy/runninghub/query?taskId — RH 任务轮询(转存)",
        "GET /api/proxy/runninghub/app-info?webappId — RH 应用信息"
      ]
    }
